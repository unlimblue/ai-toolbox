# AI-Toolbox 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# AI Provider API Keys
KIMI_API_KEY=your_kimi_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# API Server 配置
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your_api_key_for_protection  # 可选，用于保护 API

# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# 日志级别
LOG_LEVEL=INFO